/ {
	aliases {
		connection-status = &led1;
		core-status = &led3;
		device-type = &led0;
		audio-status = &led2;
	};
};

&usbd {
	hs_0: hs_0 {
		compatible = "usb-audio-hs";
		mic-feature-mute;
		mic-channel-l;
		mic-channel-r;

		hp-feature-mute;
		hp-channel-l;
		hp-channel-r;
	};
};
